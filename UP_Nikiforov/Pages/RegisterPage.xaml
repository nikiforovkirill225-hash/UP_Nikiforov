<Page x:Class="UP_Nikiforov.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP_Nikiforov.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="📝 Создание аккаунта"
      Background="#FFF0F2F5">

    <Grid Background="#FFF0F2F5">
        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="460"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Основная карточка регистрации -->
            <Border Grid.Column="1" 
                    Background="White" 
                    Padding="36"
                    BorderBrush="#FFE2E8F0"
                    BorderThickness="1">

                <StackPanel>
                    <!-- Логотип -->
                    <Border Width="64" 
                            Height="64" 
                            Background="#FFE94560" 
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20">
                        <TextBlock Text="📖" FontSize="34" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Заголовок -->
                    <TextBlock Text="Добро пожаловать!" 
                               FontSize="22" 
                               FontWeight="Bold" 
                               Foreground="#FF1A1A2E" 
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>

                    <TextBlock Text="Создайте аккаунт в литературной вселенной" 
                               FontSize="13" 
                               Foreground="#FF7F8C9A" 
                               HorizontalAlignment="Center"
                               Margin="0,0,0,28"/>

                    <!-- Поле Логин -->
                    <TextBlock Text="🔑 Логин" 
                               FontSize="12" 
                               FontWeight="SemiBold" 
                               Foreground="#FF5A6E7A"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="tbLogin" 
                             Height="42"
                             Margin="0,0,0,16"
                             Padding="14,0"
                             BorderBrush="#FFD5DEE5"
                             BorderThickness="1"
                             Background="White"
                             Foreground="#FF2C3E50"
                             FontSize="13"/>

                    <!-- Поле Пароль -->
                    <TextBlock Text="🔒 Пароль" 
                               FontSize="12" 
                               FontWeight="SemiBold" 
                               Foreground="#FF5A6E7A"
                               Margin="0,0,0,6"/>
                    <PasswordBox x:Name="pbPassword" 
                                 Height="42"
                                 Margin="0,0,0,16"
                                 Padding="14,0"
                                 BorderBrush="#FFD5DEE5"
                                 BorderThickness="1"
                                 Background="White"
                                 Foreground="#FF2C3E50"
                                 FontSize="13"/>

                    <!-- Поле Email -->
                    <TextBlock Text="📧 Электронная почта" 
                               FontSize="12" 
                               FontWeight="SemiBold" 
                               Foreground="#FF5A6E7A"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="tbEmail" 
                             Height="42"
                             Margin="0,0,0,16"
                             Padding="14,0"
                             BorderBrush="#FFD5DEE5"
                             BorderThickness="1"
                             Background="White"
                             Foreground="#FF2C3E50"
                             FontSize="13"/>

                    <!-- Поле Отображаемое имя -->
                    <TextBlock Text="👤 Отображаемое имя" 
                               FontSize="12" 
                               FontWeight="SemiBold" 
                               Foreground="#FF5A6E7A"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="tbDisplayName" 
                             Height="42"
                             Margin="0,0,0,24"
                             Padding="14,0"
                             BorderBrush="#FFD5DEE5"
                             BorderThickness="1"
                             Background="White"
                             Foreground="#FF2C3E50"
                             FontSize="13"/>

                    <!-- Сообщение об ошибке -->
                    <TextBlock x:Name="tbError" 
                               Foreground="#FFE74C3C" 
                               FontSize="12"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16"/>

                    <!-- Кнопки действий -->
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="btnBack" 
                                Grid.Column="0"
                                Content="← Назад" 
                                Height="44"
                                Background="#FF95A5A6"
                                Foreground="White"
                                FontSize="13"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Click="btnBack_Click"/>

                        <Button x:Name="btnRegister" 
                                Grid.Column="2"
                                Content="Создать аккаунт →" 
                                Height="44"
                                Background="#FF27AE60"
                                Foreground="White"
                                FontSize="13"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Click="btnRegister_Click"/>
                    </Grid>

                    <!-- Ссылка на вход -->
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center" 
                                Margin="0,24,0,0">
                        <TextBlock Text="Уже есть аккаунт?" 
                                   FontSize="12" 
                                   Foreground="#FF7F8C9A"/>
                        <Button x:Name="btnGoToLogin" 
                                Content="Войти"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#FF3498DB"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Margin="6,0,0,0"
                                Click="btnGoToLogin_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>