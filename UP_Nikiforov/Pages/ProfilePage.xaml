<Page x:Class="UP_Nikiforov.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP_Nikiforov.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="👤 Управление профилем" 
      Loaded="Page_Loaded"
      Background="#FFF0F2F5">

    <Page.Resources>
        <Style x:Key="ProfileCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="20"/>
            <Setter Property="Padding" Value="28"/>
        </Style>

        <Style x:Key="InfoRowStyle" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#FF7F8C9A"/>
            <Setter Property="Width" Value="140"/>
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#FF2C3E50"/>
        </Style>

        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="LogoutButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="#FFE74C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Page.Resources>

    <Grid Background="#FFF0F2F5">
        <!-- Заголовок страницы -->
        <Border Background="White" 
                Padding="24,20" 
                Margin="0,0,0,24"
                BorderBrush="#FFE2E8F0"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Border Width="50" Height="50" Background="#FFE94560" Margin="0,0,16,0">
                    <TextBlock Text="👤" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel>
                    <TextBlock Text="Личный кабинет" FontSize="22" FontWeight="Bold" Foreground="#FF1A1A2E"/>
                    <TextBlock Text="Управление данными и статистика" FontSize="12" Foreground="#FF7F8C9A"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая карточка: Информация о пользователе -->
            <Border Grid.Column="0" Style="{StaticResource ProfileCardStyle}">
                <StackPanel>
                    <!-- Аватар-заглушка -->
                    <Border Width="80" Height="80" 
                            Background="#FFF0F2F5"
                            BorderBrush="#FFE2E8F0"
                            BorderThickness="2"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20">
                        <TextBlock Text="📖" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Информация об аккаунте" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="#FF1A1A2E" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,24"/>

                    <!-- Логин -->
                    <StackPanel Style="{StaticResource InfoRowStyle}">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="🔑 Логин:"/>
                        <TextBlock x:Name="tblLogin" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>

                    <!-- Имя в системе -->
                    <StackPanel Style="{StaticResource InfoRowStyle}">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="👤 Имя в системе:"/>
                        <TextBlock x:Name="tblDisplayName" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>

                    <!-- Email -->
                    <StackPanel Style="{StaticResource InfoRowStyle}">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="📧 Email:"/>
                        <TextBlock x:Name="tblEmail" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>

                    <!-- Роль -->
                    <StackPanel Style="{StaticResource InfoRowStyle}">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="⭐ Роль:"/>
                        <Border Background="#FFF0F7FF" Padding="12,4" HorizontalAlignment="Left">
                            <TextBlock x:Name="tblRole" 
                                       FontSize="12" 
                                       FontWeight="SemiBold" 
                                       Foreground="#FF3498DB"/>
                        </Border>
                    </StackPanel>

                    <!-- Разделитель -->
                    <Border Height="1" Background="#FFE2E8F0" Margin="0,8,0,24"/>

                    <!-- Кнопка выхода -->
                    <Button x:Name="btnLogout" 
                            Content="🚪 Выйти из аккаунта" 
                            Style="{StaticResource LogoutButtonStyle}"
                            Click="btnLogout_Click"/>

                    <!-- Кнопка подачи заявки на автора -->
                    <Button x:Name="btnRequestAuthor" 
                            Content="✍️ Подать заявку на роль автора"
                            Height="44"
                            Background="#FF3498DB"
                            Foreground="White"
                            FontSize="13"
                            FontWeight="SemiBold"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,12,0,0"
                            Visibility="Collapsed"
                            Click="btnRequestAuthor_Click"/>
                </StackPanel>
            </Border>

            <!-- Правая карточка: Активность -->
            <Border Grid.Column="1" Style="{StaticResource ProfileCardStyle}">
                <StackPanel>
                    <TextBlock Text="📊 Статистика активности" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="#FF1A1A2E" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,24"/>

                    <!-- Книги в списках -->
                    <Border Style="{StaticResource StatCardStyle}" Background="#FFF4F6F9">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="📚" FontSize="20" Margin="0,0,10,0"/>
                                <TextBlock Text="Книг в списках чтения" 
                                           FontSize="14" 
                                           FontWeight="SemiBold" 
                                           Foreground="#FF5A6E7A"/>
                            </StackPanel>
                            <TextBlock x:Name="tblBooksInListsCount" 
                                       Text="0" 
                                       FontSize="36" 
                                       FontWeight="Bold" 
                                       Foreground="#FF3498DB"/>
                        </StackPanel>
                    </Border>

                    <!-- Статистика автора -->
                    <Border x:Name="borderAuthorStats" 
                            Style="{StaticResource StatCardStyle}" 
                            Background="#FFF0F9F0"
                            Visibility="Collapsed">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="✍️" FontSize="20" Margin="0,0,10,0"/>
                                <TextBlock Text="Опубликованных произведений" 
                                           FontSize="14" 
                                           FontWeight="SemiBold" 
                                           Foreground="#FF5A6E7A"/>
                            </StackPanel>
                            <TextBlock x:Name="tblAuthorBooksCount" 
                                       Text="0" 
                                       FontSize="36" 
                                       FontWeight="Bold" 
                                       Foreground="#FF27AE60"/>
                        </StackPanel>
                    </Border>

                    <!-- Отзывы пользователя -->
                    <Border Style="{StaticResource StatCardStyle}" Background="#FFFFF5F0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="💬" FontSize="20" Margin="0,0,10,0"/>
                                <TextBlock Text="Оставленных отзывов" 
                                           FontSize="14" 
                                           FontWeight="SemiBold" 
                                           Foreground="#FF5A6E7A"/>
                            </StackPanel>
                            <TextBlock x:Name="tblUserReviewsCount" 
                                       Text="0" 
                                       FontSize="36" 
                                       FontWeight="Bold" 
                                       Foreground="#FFE67E22"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>