<Page x:Class="UP_Nikiforov.Pages.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP_Nikiforov.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="📚 Библиотека произведений" 
      Loaded="Page_Loaded"
      Background="#FFF0F2F5">

    <Page.Resources>
        <!-- Стиль для карточки книги -->
        <Style x:Key="BookCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="Height" Value="300"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#FFD5DEE5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#FF2C3E50"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#FFD5DEE5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#FF2C3E50"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFE2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FF2C3E50"/>
        </Style>
    </Page.Resources>

    <Grid Background="#FFF0F2F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка страницы -->
        <Border Grid.Row="0" 
                Background="White" 
                Padding="20,16" 
                Margin="0,0,0,16"
                BorderBrush="#FFE2E8F0"
                BorderThickness="0,0,0,1">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Border Width="44" Height="44" Background="#FFE94560" Margin="0,0,16,0">
                        <TextBlock Text="📚" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="Каталог книг" FontSize="20" FontWeight="Bold" Foreground="#FF1A1A2E"/>
                        <TextBlock Text="Исследуйте коллекцию произведений" FontSize="12" Foreground="#FF7F8C9A"/>
                    </StackPanel>
                </StackPanel>

                <!-- Панель фильтров -->
                <Border Background="#FFF8F9FC" 
                        Padding="16,12" 
                        Margin="0,4,0,0"
                        BorderBrush="#FFE2E8F0"
                        BorderThickness="1">
                    <WrapPanel VerticalAlignment="Center">
                        <!-- Поиск -->
                        <Border Background="White" BorderBrush="#FFD5DEE5" BorderThickness="1" Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔍 " FontSize="14" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                <TextBox x:Name="tbSearch" 
                                         Width="200" 
                                         BorderThickness="0"
                                         Background="Transparent"
                                         TextChanged="tbSearch_TextChanged"/>
                            </StackPanel>
                        </Border>

                        <!-- Сортировка -->
                        <Border Background="White" BorderBrush="#FFD5DEE5" BorderThickness="1" Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊 " FontSize="12" VerticalAlignment="Center" Margin="10,0,5,0" Foreground="#FF5A6E7A"/>
                                <TextBlock Text="Сортировка:" VerticalAlignment="Center" FontSize="12" Foreground="#FF5A6E7A" Margin="0,0,8,0"/>
                                <ComboBox x:Name="cbSort" 
                                          Width="160" 
                                          BorderThickness="0"
                                          Background="Transparent"
                                          SelectionChanged="cbSort_SelectionChanged">
                                    <ComboBoxItem Content="📋 Без сортировки"/>
                                    <ComboBoxItem Content="🔤 По алфавиту (А→Я)"/>
                                    <ComboBoxItem Content="🔤 По алфавиту (Я→А)"/>
                                    <ComboBoxItem Content="⭐ По оценке (↑ высшая)"/>
                                    <ComboBoxItem Content="⭐ По оценке (↓ низшая)"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- Жанр -->
                        <Border Background="White" BorderBrush="#FFD5DEE5" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏷️ " FontSize="12" VerticalAlignment="Center" Margin="10,0,5,0" Foreground="#FF5A6E7A"/>
                                <TextBlock Text="Жанр:" VerticalAlignment="Center" FontSize="12" Foreground="#FF5A6E7A" Margin="0,0,8,0"/>
                                <ComboBox x:Name="cbGenre" 
                                          Width="160" 
                                          BorderThickness="0"
                                          Background="Transparent"
                                          SelectionChanged="cbGenre_SelectionChanged"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Сетка книг -->
        <Border Grid.Row="1" Margin="16,0,16,16">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ListView x:Name="lvBooks" 
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          BorderThickness="0"
                          Background="Transparent"
                          MouseDoubleClick="lvBooks_MouseDoubleClick">

                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" 
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Top"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource BookCardStyle}">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="📖 Добавить в 'Хочу прочитать'" Click="MenuWantToRead_Click"/>
                                        <MenuItem Header="📚 Добавить в 'Читаю'" Click="MenuReadingNow_Click"/>
                                        <MenuItem Header="✅ Добавить в 'Прочитано'" Click="MenuRead_Click"/>
                                    </ContextMenu>
                                </Border.ContextMenu>

                                <Grid Margin="12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Обложка -->
                                    <Border Grid.Row="0" 
                                            Background="#FFF8F9FC"
                                            Margin="0,0,0,10">
                                        <Image Source="{Binding CoverPath}" 
                                               Stretch="UniformToFill" 
                                               MaxHeight="160"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>

                                    <!-- Название -->
                                    <TextBlock Grid.Row="1" 
                                               Text="{Binding Title}" 
                                               FontWeight="Bold" 
                                               FontSize="13" 
                                               TextWrapping="Wrap" 
                                               MaxHeight="38" 
                                               TextTrimming="CharacterEllipsis" 
                                               HorizontalAlignment="Center" 
                                               TextAlignment="Center"
                                               Foreground="#FF1A1A2E"
                                               Margin="0,8,0,4"/>

                                    <!-- Автор -->
                                    <Border Grid.Row="2" 
                                            Background="#FFF0F2F5" 
                                            Padding="8,3" 
                                            HorizontalAlignment="Center"
                                            Margin="0,4,0,0">
                                        <TextBlock Text="{Binding Users.DisplayName}" 
                                                   FontSize="10" 
                                                   Foreground="#FF5A6E7A"
                                                   HorizontalAlignment="Center"/>
                                    </Border>

                                    <!-- Рейтинг (если есть) -->
                                    <Border Grid.Row="3" 
                                            Background="Transparent" 
                                            HorizontalAlignment="Center"
                                            Margin="0,8,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⭐ " FontSize="10" Foreground="#FFF1C40F"/>
                                            <TextBlock Text="{Binding AvgRating, StringFormat=\{0:F1\}}" 
                                                       FontSize="10" 
                                                       Foreground="#FFBDC3C7"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>