<Page x:Class="UP_Nikiforov.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP_Nikiforov.Pages"
      mc:Ignorable="d" 
      Title="🔐 Центр управления" 
      Loaded="Page_Loaded"
      Background="#FFF0F2F5" d:DesignHeight="240.312">

    <Page.Resources>
        <!-- Стиль для вкладок -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="16"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF5A6E7A"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid>
                            <Border x:Name="Border" 
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="0,0,0,3"
                                    BorderBrush="Transparent"
                                    CornerRadius="0">
                                <ContentPresenter x:Name="ContentSite"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#FFE94560"/>
                                <Setter Property="Foreground" Value="#FF1A1A2E"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#FFE94560"/>
                                <Setter Property="Foreground" Value="#FFE94560"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFE2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="45"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="AlternatingRowBackground" Value="#FFF9FAFB"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGrid">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ScrollViewer>
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFF8F9FC"/>
            <Setter Property="Foreground" Value="#FF2C3E50"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="BorderBrush" Value="#FFE2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#FF3A4D61"/>
        </Style>

        <!-- Стили для кнопок действий -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Background="#FFF0F2F5">

            <!-- Шапка страницы -->
            <Border Background="White" 
                    CornerRadius="0,0,20,20" 
                    Padding="20,16" 
                    Margin="0,0,0,16"
                    BorderBrush="#FFE2E8F0"
                    BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <Border Width="44" Height="44" CornerRadius="12" Background="#FFE94560" Margin="0,0,16,0">
                        <TextBlock Text="🛡️" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="Панель администратора" FontSize="18" FontWeight="Bold" Foreground="#FF1A1A2E"/>
                        <TextBlock Text="Управление жалобами и блокировками" FontSize="12" Foreground="#FF7F8C9A"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TabControl Margin="16,0,16,16">

                <!-- Вкладка: Входящие жалобы -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠️ " Margin="0,0,4,0"/>
                            <TextBlock Text="Входящие жалобы"/>
                        </StackPanel>
                    </TabItem.Header>

                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" CornerRadius="12" Margin="0,0,0,16">
                            <DataGrid x:Name="dgComplaints" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding ID}" Width="50"/>
                                    <DataGridTextColumn Header="🆔 Отправитель" Binding="{Binding SenderID}" Width="90"/>
                                    <DataGridTextColumn Header="📖 Книга" Binding="{Binding TargetBookID}" Width="70"/>
                                    <DataGridTextColumn Header="💬 Отзыв" Binding="{Binding TargetReviewID}" Width="70"/>
                                    <DataGridTextColumn Header="📋 Причина" Binding="{Binding Reason}" Width="*"/>
                                    <DataGridTextColumn Header="📅 Дата" Binding="{Binding CreatedAt, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" Width="130"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Right" Margin="0,8,0,8">
                            <Button x:Name="btnReject" 
                                    Content="✕ Отклонить" 
                                    Style="{StaticResource ActionButtonStyle}"
                                    Background="#FF95A5A6" 
                                    Click="btnReject_Click" 
                                    Margin="0,0,12,0"/>
                            <Button x:Name="btnFreezeBook" 
                                    Content="🔒 Заморозить книгу" 
                                    Style="{StaticResource ActionButtonStyle}"
                                    Background="#FFE67E22" 
                                    Click="btnFreezeBook_Click" 
                                    Margin="0,0,12,0"/>
                            <Button x:Name="btnFreezeUser" 
                                    Content="🚫 Заморозить автора" 
                                    Style="{StaticResource ActionButtonStyle}"
                                    Background="#FFC0392B" 
                                    Click="btnFreezeUser_Click"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- Вкладка: Замороженные книги -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📚 " Margin="0,0,4,0"/>
                            <TextBlock Text="Замороженные книги"/>
                        </StackPanel>
                    </TabItem.Header>

                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" CornerRadius="12" Margin="0,0,0,16">
                            <DataGrid x:Name="dgFrozenBooks" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding ID}" Width="60"/>
                                    <DataGridTextColumn Header="📖 Название" Binding="{Binding Title}" Width="250"/>
                                    <DataGridTextColumn Header="✍️ Автор" Binding="{Binding AuthorID}" Width="100"/>
                                    <DataGridTextColumn Header="📄 Описание" Binding="{Binding Description}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Button x:Name="btnUnfreezeBook" 
                                Content="🔓 Разморозить книгу" 
                                Grid.Row="1" 
                                HorizontalAlignment="Right" 
                                Style="{StaticResource ActionButtonStyle}"
                                Background="#FF2ECC71" 
                                FontWeight="Bold" 
                                Click="btnUnfreezeBook_Click"/>
                    </Grid>
                </TabItem>

                <!-- Вкладка: Замороженные пользователи -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥 " Margin="0,0,4,0"/>
                            <TextBlock Text="Замороженные пользователи"/>
                        </StackPanel>
                    </TabItem.Header>

                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" CornerRadius="12" Margin="0,0,0,16">
                            <DataGrid x:Name="dgFrozenUsers" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding ID}" Width="60"/>
                                    <DataGridTextColumn Header="🔑 Логин" Binding="{Binding Login}" Width="150"/>
                                    <DataGridTextColumn Header="👤 Имя" Binding="{Binding DisplayName}" Width="200"/>
                                    <DataGridTextColumn Header="📧 Email" Binding="{Binding Email}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Button x:Name="btnUnfreezeUser" 
                                Content="✅ Разблокировать пользователя" 
                                Grid.Row="1" 
                                HorizontalAlignment="Right" 
                                Style="{StaticResource ActionButtonStyle}"
                                Background="#FF2ECC71" 
                                FontWeight="Bold" 
                                Click="btnUnfreezeUser_Click"/>
                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>
    </ScrollViewer>
</Page>