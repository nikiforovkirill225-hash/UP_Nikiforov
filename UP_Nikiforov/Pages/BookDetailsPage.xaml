<Page x:Class="UP_Nikiforov.Pages.BookDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP_Nikiforov.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="📖 Страница произведения" 
      Loaded="Page_Loaded"
      Background="#FFF0F2F5">

    <Page.Resources>
        <!-- Стиль для кнопок действий -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для маленьких кнопок -->
        <Style x:Key="SmallButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- Стиль для отзывов -->
        <Style x:Key="ReviewCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="BorderBrush" Value="#FFE2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="#FFE2E8F0"/>
            <Setter Property="Margin" Value="0,8"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Background="#FFF0F2F5">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Шапка с кнопкой назад -->
                <Border Grid.Row="0" 
                        Background="White" 
                        CornerRadius="16" 
                        Padding="16,12" 
                        Margin="0,0,0,20"
                        BorderBrush="#FFE2E8F0"
                        BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="btnBack" 
                                Content="← Вернуться" 
                                Style="{StaticResource SmallButtonStyle}"
                                Background="#FF7F8C9A" 
                                Click="btnBack_Click"/>
                        <TextBlock Text="📖 Детали произведения" 
                                   FontSize="14" 
                                   Foreground="#FF7F8C9A" 
                                   VerticalAlignment="Center"
                                   Margin="16,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Основная информация о книге -->
                <Border Grid.Row="1" 
                        Background="White" 
                        CornerRadius="16" 
                        Padding="24" 
                        Margin="0,0,0,24"
                        BorderBrush="#FFE2E8F0"
                        BorderThickness="1">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Обложка -->
                        <Border Grid.Column="0" 
                                CornerRadius="12" 
                                Background="#FFF8F9FC"
                                BorderBrush="#FFE2E8F0"
                                BorderThickness="1"
                                Padding="12"
                                HorizontalAlignment="Left"
                                Width="200">
                            <Image Source="{Binding CoverPath}" 
                                   Stretch="Uniform" 
                                   MaxHeight="280"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>

                        <!-- Информация -->
                        <StackPanel Grid.Column="1" Margin="24,0,0,0">
                            <TextBlock Text="{Binding Title}" 
                                       FontSize="26" 
                                       FontWeight="Bold" 
                                       Foreground="#FF1A1A2E"
                                       TextWrapping="Wrap"/>

                            <Border Background="#FFF0F2F5" 
                                    CornerRadius="20" 
                                    Padding="12,6" 
                                    Margin="0,12,0,0"
                                    HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✍️ " FontSize="12"/>
                                    <TextBlock x:Name="tblAuthor" FontSize="13" Foreground="#FF5A6E7A"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,12,0,16">
                                <Border Background="#FFFDF0" CornerRadius="20" Padding="8,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⭐ " FontSize="12"/>
                                        <TextBlock x:Name="tblRating" FontSize="13" FontWeight="SemiBold" Foreground="#FFF1C40F"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <Separator/>

                            <TextBlock Text="📄 Аннотация" 
                                       FontSize="14" 
                                       FontWeight="Bold" 
                                       Foreground="#FF2C3E50"
                                       Margin="0,16,0,8"/>
                            <TextBlock Text="{Binding Description}" 
                                       FontSize="13" 
                                       TextWrapping="Wrap" 
                                       Foreground="#FF5A6E7A"
                                       LineHeight="22"/>

                            <Separator Margin="0,20,0,20"/>

                            <!-- Кнопки действий -->
                            <WrapPanel Margin="0,0,0,16">
                                <Button x:Name="btnRead" 
                                        Content="📖 Читать" 
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#FF27AE60" 
                                        Click="btnRead_Click" 
                                        Margin="0,0,12,8"/>

                                <Button x:Name="btnComplainBook" 
                                        Content="⚠️ Жалоба на книгу" 
                                        Style="{StaticResource SmallButtonStyle}"
                                        Background="#FFE67E22" 
                                        Click="btnComplainBook_Click" 
                                        Margin="0,0,12,8"/>

                                <Button x:Name="btnComplainAuthor" 
                                        Content="⚠️ Жалоба на автора" 
                                        Style="{StaticResource SmallButtonStyle}"
                                        Background="#FFD35400" 
                                        Click="btnComplainAuthor_Click" 
                                        Margin="0,0,20,8"/>

                                <Button x:Name="btnAdminFreezeBook" 
                                        Content="🔒 Заморозить книгу" 
                                        Style="{StaticResource SmallButtonStyle}"
                                        Background="#FFC0392B" 
                                        Click="btnAdminFreezeBook_Click" 
                                        Visibility="Collapsed"/>

                                <Border Background="#FFF8F9FC" CornerRadius="20" Padding="12,0" Margin="10,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📌 Статус:" VerticalAlignment="Center" FontSize="12" Foreground="#FF5A6E7A" Margin="0,0,8,0"/>
                                        <ComboBox x:Name="cbBookStatus" 
                                                  Width="140" 
                                                  Height="32"
                                                  SelectionChanged="cbBookStatus_SelectionChanged"
                                                  Background="White"
                                                  BorderBrush="#FFD5DEE5"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Блок отзывов -->
                <Border Grid.Row="2" 
                        Background="White" 
                        CornerRadius="16" 
                        Padding="24" 
                        BorderBrush="#FFE2E8F0"
                        BorderThickness="1">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Заголовок -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Width="4" Height="20" Background="#FFE94560" CornerRadius="2" Margin="0,0,12,0"/>
                            <TextBlock Text="💬 Отзывы читателей" FontSize="18" FontWeight="Bold" Foreground="#FF1A1A2E"/>
                            <Border Background="#FFE8ECF2" CornerRadius="20" Padding="8,3" Margin="12,0,0,0">
                                <TextBlock x:Name="ReviewsCountText" Text="0 отзывов" FontSize="11" Foreground="#FF5A6E7A"/>
                            </Border>
                        </StackPanel>

                        <!-- Форма добавления отзыва -->
                        <Border x:Name="borderAddReview" 
                                Grid.Row="1"
                                Background="#FFF8F9FC" 
                                CornerRadius="16" 
                                Padding="20" 
                                Margin="0,0,0,24"
                                BorderBrush="#FFE2E8F0"
                                BorderThickness="1">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="✍️ Написать отзыв" 
                                           FontSize="14" 
                                           FontWeight="SemiBold" 
                                           Foreground="#FF2C3E50"
                                           Margin="0,0,0,16"/>

                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock Text="⭐ Оценка (1–10):" VerticalAlignment="Center" FontSize="13" Margin="0,0,12,0"/>
                                    <ComboBox x:Name="cbRating" 
                                              Width="70" 
                                              Height="32"
                                              Background="White"
                                              BorderBrush="#FFD5DEE5"
                                              SelectionBoxItemFontWeight="SemiBold">
                                        <ComboBoxItem Content="1"/>
                                        <ComboBoxItem Content="2"/>
                                        <ComboBoxItem Content="3"/>
                                        <ComboBoxItem Content="4"/>
                                        <ComboBoxItem Content="5"/>
                                        <ComboBoxItem Content="6"/>
                                        <ComboBoxItem Content="7"/>
                                        <ComboBoxItem Content="8"/>
                                        <ComboBoxItem Content="9"/>
                                        <ComboBoxItem Content="10" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>

                                <TextBox x:Name="tbReviewText" 
                                         Grid.Row="2" 
                                         Height="80" 
                                         TextWrapping="Wrap" 
                                         AcceptsReturn="True" 
                                         VerticalContentAlignment="Top"
                                         BorderBrush="#FFD5DEE5"
                                         BorderThickness="1"
                                         CornerRadius="10"
                                         Padding="12,8"
                                         Foreground="#FF2C3E50"
                                         SelectionBrush="#FFE94560"/>

                                <Button x:Name="btnSendReview" 
                                        Grid.Row="2"
                                        Content="📤 Опубликовать отзыв" 
                                        HorizontalAlignment="Right"
                                        Width="160"
                                        Height="36"
                                        Margin="0,12,0,0"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#FF3498DB" 
                                        Click="btnSendReview_Click"/>
                            </Grid>
                        </Border>

                        <!-- Список отзывов -->
                        <Border Grid.Row="2" CornerRadius="12">
                            <ListView x:Name="lvReviews" 
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      BorderThickness="0">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ReviewCardStyle}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" 
                                                               Text="{Binding Users.DisplayName}" 
                                                               FontWeight="Bold" 
                                                               FontSize="14"
                                                               Foreground="#FF1A1A2E"/>

                                                    <Border Grid.Column="1" 
                                                            Background="#FFFDF0" 
                                                            CornerRadius="15" 
                                                            Padding="10,4">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="⭐ " FontSize="11"/>
                                                            <TextBlock Text="{Binding Rating}" 
                                                                       FontWeight="Bold" 
                                                                       Foreground="#FFF1C40F"
                                                                       FontSize="12"/>
                                                            <TextBlock Text=" / 10" FontSize="10" Foreground="#FFBDC3C7"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>

                                                <TextBlock Grid.Row="1" 
                                                           Text="{Binding Text}" 
                                                           FontSize="13" 
                                                           TextWrapping="Wrap" 
                                                           Foreground="#FF5A6E7A"
                                                           Margin="0,10,0,10"
                                                           LineHeight="20"/>

                                                <TextBlock Grid.Row="2" 
                                                           Text="{Binding CreatedAt, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" 
                                                           FontSize="11" 
                                                           Foreground="#FFBDC3C7"
                                                           HorizontalAlignment="Left"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>

                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                            </ListView>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>