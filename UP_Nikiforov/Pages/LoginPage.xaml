<Page x:Class="UP_Nikiforov.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP_Nikiforov.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="🔐 Вход в систему" 
      Loaded="Page_Loaded"
      Background="#FFF0F2F5">

    <Grid Background="#FFF0F2F5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="480"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Центральная карточка -->
        <Border Grid.Column="1" 
                Background="White" 
                Margin="0,40" 
                VerticalAlignment="Center"
                BorderBrush="#FFE2E8F0"
                BorderThickness="1">

            <Grid Margin="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Логотип -->
                <Border Grid.Row="0" 
                        Width="80" 
                        Height="80" 
                        Background="#FFE94560" 
                        HorizontalAlignment="Center"
                        Margin="0,0,0,20">
                    <TextBlock Text="📚" FontSize="44" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Заголовок -->
                <TextBlock Grid.Row="1" 
                           Text="Читай, Пиши и не спиши" 
                           FontSize="22" 
                           FontWeight="Bold" 
                           Foreground="#FF1A1A2E"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>

                <TextBlock Grid.Row="2" 
                           Text="Добро пожаловать обратно!" 
                           FontSize="14" 
                           Foreground="#FF7F8C9A"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,32"/>

                <!-- Поле Логин -->
                <StackPanel Grid.Row="3" Margin="0,0,0,16">
                    <TextBlock Text="Электронная почта или логин" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Foreground="#FF2C3E50"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="tbLogin" 
                             Height="46"
                             Padding="16,0"
                             BorderBrush="#FFD5DEE5"
                             BorderThickness="1"
                             Background="White"
                             Foreground="#FF2C3E50"
                             FontSize="14"/>
                </StackPanel>

                <!-- Поле Пароль -->
                <StackPanel Grid.Row="4" Margin="0,0,0,24">
                    <TextBlock Text="Пароль" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Foreground="#FF2C3E50"
                               Margin="0,0,0,8"/>
                    <PasswordBox x:Name="pbPassword" 
                                 Height="46"
                                 Padding="16,0"
                                 BorderBrush="#FFD5DEE5"
                                 BorderThickness="1"
                                 Background="White"
                                 Foreground="#FF2C3E50"
                                 FontSize="14"/>
                </StackPanel>

                <!-- Кнопка входа -->
                <Button x:Name="btnLogin" 
                        Grid.Row="5"
                        Content="🔓 Войти в аккаунт" 
                        Height="48"
                        Background="#FFE94560"
                        Foreground="White"
                        FontSize="15"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Click="btnLogin_Click"
                        Margin="0,0,0,16"/>

                <!-- Разделитель -->
                <Grid Grid.Row="6" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Height="1" Background="#FFE2E8F0" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="или" FontSize="12" Foreground="#FF95A5A6" Margin="16,0" VerticalAlignment="Center"/>
                    <Border Grid.Column="2" Height="1" Background="#FFE2E8F0" VerticalAlignment="Center"/>
                </Grid>

                <!-- Кнопка регистрации -->
                <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Нет аккаунта?" FontSize="13" Foreground="#FF5A6E7A" VerticalAlignment="Center"/>
                    <Button x:Name="btnRegister" 
                            Content="Зарегистрироваться" 
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#FF3498DB"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Margin="8,0,0,0"
                            Click="btnRegister_Click"/>
                </StackPanel>

                <!-- Сообщение об ошибке -->
                <TextBlock x:Name="tbError" 
                           Grid.Row="8"
                           Foreground="#FFE74C3C" 
                           FontSize="12"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</Page>