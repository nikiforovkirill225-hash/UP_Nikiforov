<Page x:Class="UP_Nikiforov.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP_Nikiforov.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="🔐 Вход в систему" 
      Loaded="Page_Loaded"
      Background="#FFF0F2F5">

    <Page.Resources>
        <!-- Стиль для полей ввода -->
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#FFD5DEE5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#FF2C3E50"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#FF3498DB"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#FFE94560"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#FFD5DEE5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#FF2C3E50"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#FF3498DB"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#FFE94560"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для кнопки входа -->
        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="#FFE94560"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FF3498DB"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#FFE94560"/>
                                <Setter Property="TextDecorations" Value="Underline"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="#FFF0F2F5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="480"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Центральная карточка -->
        <Border Grid.Column="1" 
                Background="White" 
                CornerRadius="28" 
                Margin="0,40" 
                VerticalAlignment="Center"
                Effect="{DynamicResource {x:Static SystemParameters.DropShadowKey}}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Direction="270" Opacity="0.1" ShadowDepth="8"/>
            </Border.Effect>

            <Grid Margin="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Логотип -->
                <Border Grid.Row="0" 
                        Width="80" 
                        Height="80" 
                        CornerRadius="24" 
                        Background="#FFE94560" 
                        HorizontalAlignment="Center"
                        Margin="0,0,0,20">
                    <TextBlock Text="📚" FontSize="44" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Заголовок -->
                <TextBlock Grid.Row="1" 
                           Text="Читай, Пиши и не спиши" 
                           FontSize="22" 
                           FontWeight="Bold" 
                           Foreground="#FF1A1A2E"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>

                <TextBlock Grid.Row="2" 
                           Text="Добро пожаловать обратно!" 
                           FontSize="14" 
                           Foreground="#FF7F8C9A"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,32"/>

                <!-- Поле Логин -->
                <StackPanel Grid.Row="3" Margin="0,0,0,16">
                    <TextBlock Text="Электронная почта или логин" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Foreground="#FF2C3E50"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="tbLogin" 
                             Style="{StaticResource ModernTextBoxStyle}"
                             PlaceholderText="example@mail.com или username">
                        <TextBox.Resources>
                            <VisualBrush x:Key="HintBrush" 
                                         Visual="{Binding ElementName=HintText}" 
                                         Stretch="None" 
                                         AlignmentX="Left" 
                                         AlignmentY="Center"/>
                            <TextBlock x:Key="HintText" 
                                       Text="example@mail.com или username" 
                                       Foreground="#FFBDC3C7" 
                                       FontSize="14"
                                       VerticalAlignment="Center"/>
                        </TextBox.Resources>
                    </TextBox>
                </StackPanel>

                <!-- Поле Пароль -->
                <StackPanel Grid.Row="4" Margin="0,0,0,24">
                    <TextBlock Text="Пароль" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Foreground="#FF2C3E50"
                               Margin="0,0,0,8"/>
                    <PasswordBox x:Name="pbPassword" 
                                 Style="{StaticResource ModernPasswordBoxStyle}"/>
                </StackPanel>

                <!-- Кнопка входа -->
                <Button x:Name="btnLogin" 
                        Grid.Row="5"
                        Content="🔓 Войти в аккаунт" 
                        Style="{StaticResource LoginButtonStyle}"
                        Click="btnLogin_Click"
                        Margin="0,0,0,16"/>

                <!-- Разделитель -->
                <Grid Grid.Row="6" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Height="1" Background="#FFE2E8F0" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="или" FontSize="12" Foreground="#FF95A5A6" Margin="16,0" VerticalAlignment="Center"/>
                    <Border Grid.Column="2" Height="1" Background="#FFE2E8F0" VerticalAlignment="Center"/>
                </Grid>

                <!-- Кнопка регистрации -->
                <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Нет аккаунта?" FontSize="13" Foreground="#FF5A6E7A" VerticalAlignment="Center"/>
                    <Button x:Name="btnRegister" 
                            Content="Зарегистрироваться" 
                            Style="{StaticResource LinkButtonStyle}"
                            Click="btnRegister_Click"
                            Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Сообщение об ошибке -->
                <TextBlock x:Name="tbError" 
                           Grid.Row="8"
                           Foreground="#FFE74C3C" 
                           FontSize="12"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</Page>