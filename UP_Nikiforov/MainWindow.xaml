<Window x:Class="UP_Nikiforov.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UP_Nikiforov"
        mc:Ignorable="d"
        Title="📚 Читай, Пиши и не спиши ®" 
        Height="720" Width="1100"
        WindowStartupLocation="CenterScreen" 
        Loaded="Window_Loaded"
        Background="#FFF5F7FA"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Цветовая палитра бренда -->
        <SolidColorBrush x:Key="BrandDark" Color="#FF1A1A2E"/>
        <SolidColorBrush x:Key="BrandAccent" Color="#FFE94560"/>
        <SolidColorBrush x:Key="BrandLight" Color="#FF16213E"/>
        <SolidColorBrush x:Key="SurfaceColor" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="TextMuted" Color="#FF6C6F78"/>

        <!-- Стиль для кнопок сайдбара -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="56"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFE94560"/>
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FFC7354F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Иконки сайдбара (PathGeometry) -->
        <PathGeometry x:Key="IconCatalog">M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-1 9H9V9h10v2zm-4 4H9v-2h6v2zm4-8H9V5h10v2z</PathGeometry>
        <PathGeometry x:Key="IconLists">M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-8 14H7v-2h4v2zm0-4H7v-2h4v2zm0-4H7V7h4v2zm6 6h-4v-2h4v2zm0-4h-4v-2h4v2zm0-4h-4V7h4v2z</PathGeometry>
        <PathGeometry x:Key="IconAdmin">M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z</PathGeometry>
        <PathGeometry x:Key="IconAuthor">M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z</PathGeometry>
        <PathGeometry x:Key="IconWarning">M12 2L1 21h22L12 2zm0 4.2L18.5 19h-13L12 6.2zM13 16h-2v2h2v-2zm0-6h-2v4h2v-4z</PathGeometry>
        <PathGeometry x:Key="IconProfile">M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z</PathGeometry>
    </Window.Resources>

    <Grid>
        <!-- Анимированный градиентный фон -->
        <Grid.Background>
            <LinearGradientBrush EndPoint="1,1" StartPoint="0,0">
                <GradientStop Color="#FFF5F7FA" Offset="0"/>
                <GradientStop Color="#FFE8ECF2" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Стилизованный сайдбар -->
        <Border x:Name="SidebarBorder" 
                Grid.Column="0" 
                Width="88"
                Background="#FF1A1A2E"
                CornerRadius="0, 28, 28, 0"
                Margin="0, 16, 0, 16"
                Visibility="Collapsed"
                BorderBrush="#FF2D2D44"
                BorderThickness="1,0,1,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Direction="270" Opacity="0.15" ShadowDepth="5"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled"
                          Focusable="False">
                <StackPanel Margin="0, 32, 0, 32" VerticalAlignment="Top">

                    <!-- Логотип -->
                    <Border Width="56" Height="56" CornerRadius="28" Background="#FFE94560" Margin="0,0,0,24" HorizontalAlignment="Center">
                        <TextBlock Text="📖" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Каталог книг (открыт по умолчанию) -->
                    <Button x:Name="btnCatalog" 
                            Style="{StaticResource NavButtonStyle}"
                            Click="btnCatalog_Click"
                            ToolTipService.InitialShowDelay="500">
                        <Button.ToolTip>
                            <ToolTip Content="Каталог книг" Background="#FF1A1A2E" Foreground="White" BorderBrush="#FFE94560" BorderThickness="1"/>
                        </Button.ToolTip>
                        <Viewbox Width="28" Height="28">
                            <Path Data="{StaticResource IconCatalog}" Fill="White" Stretch="Fill"/>
                        </Viewbox>
                    </Button>

                    <!-- Списки книг -->
                    <Button x:Name="btnLists" 
                            Style="{StaticResource NavButtonStyle}"
                            Click="btnLists_Click">
                        <Button.ToolTip>
                            <ToolTip Content="Списки книг" Background="#FF1A1A2E" Foreground="White"/>
                        </Button.ToolTip>
                        <Viewbox Width="28" Height="28">
                            <Path Data="{StaticResource IconLists}" Fill="White" Stretch="Fill"/>
                        </Viewbox>
                    </Button>

                    <!-- Администрирование (доступно только для администратора) -->
                    <Button x:Name="btnAdmin" 
                            Style="{StaticResource NavButtonStyle}"
                            Click="btnAdmin_Click" 
                            Visibility="Collapsed">
                        <Button.ToolTip>
                            <ToolTip Content="Администрирование" Background="#FF1A1A2E" Foreground="White"/>
                        </Button.ToolTip>
                        <Viewbox Width="28" Height="28">
                            <Path Data="{StaticResource IconAdmin}" Fill="#FFE94560" Stretch="Fill"/>
                        </Viewbox>
                    </Button>

                    <!-- Страница автора (доступно только для авторов) -->
                    <Button x:Name="btnAuthor" 
                            Style="{StaticResource NavButtonStyle}"
                            Click="btnAuthor_Click" 
                            Visibility="Collapsed">
                        <Button.ToolTip>
                            <ToolTip Content="Страница автора" Background="#FF1A1A2E" Foreground="White"/>
                        </Button.ToolTip>
                        <Viewbox Width="28" Height="28">
                            <Path Data="{StaticResource IconAuthor}" Fill="White" Stretch="Fill"/>
                        </Viewbox>
                    </Button>

                    <!-- Предупреждение о заморозке аккаунта (видно только если заморожен) -->
                    <Button x:Name="btnFreezeWarning" 
                            Style="{StaticResource NavButtonStyle}"
                            Click="btnFreezeWarning_Click" 
                            Visibility="Collapsed">
                        <Button.ToolTip>
                            <ToolTip Content="⚠️ Предупреждение о заморозке аккаунта" Background="#FF1A1A2E" Foreground="#FFFF6B6B"/>
                        </Button.ToolTip>
                        <Viewbox Width="28" Height="28">
                            <Path Data="{StaticResource IconWarning}" Fill="#FFFF6B6B" Stretch="Fill"/>
                        </Viewbox>
                    </Button>

                    <!-- Разделитель -->
                    <Rectangle Height="1" Margin="16,24,16,24" Fill="#FF2D2D44" Opacity="0.5"/>

                    <!-- Профиль -->
                    <Button x:Name="btnProfile" 
                            Style="{StaticResource NavButtonStyle}"
                            Click="btnProfile_Click">
                        <Button.ToolTip>
                            <ToolTip Content="Профиль пользователя" Background="#FF1A1A2E" Foreground="White"/>
                        </Button.ToolTip>
                        <Viewbox Width="28" Height="28">
                            <Path Data="{StaticResource IconProfile}" Fill="White" Stretch="Fill"/>
                        </Viewbox>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Основной контент с карточкой -->
        <Border Grid.Column="1" Margin="20,20,20,20" Background="Transparent">
            <Border Background="White" 
                    CornerRadius="24" 
                    BorderBrush="#FFE4E9F2" 
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Direction="270" Opacity="0.08" ShadowDepth="4"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Шапка контента -->
                    <Border Grid.Row="0" 
                            Height="56" 
                            Background="#FFF8F9FC" 
                            CornerRadius="24,24,0,0"
                            BorderBrush="#FFE4E9F2"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                            <Border Width="8" Height="8" CornerRadius="4" Background="#FFE94560" Margin="0,0,12,0"/>
                            <TextBlock Text="📖 Читай, Пиши и не спиши" 
                                       FontSize="16" 
                                       FontWeight="SemiBold"
                                       Foreground="#FF1A1A2E"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="®" FontSize="10" Foreground="#FFE94560" Margin="4,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Frame для страниц -->
                    <Frame x:Name="MainFrame" 
                           Grid.Row="1" 
                           NavigationUIVisibility="Hidden"
                           Background="White"
                           BorderThickness="0"/>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>